Step 4: Contact.aspx (Content Page) 
Contact.aspx 
<%@ Page Title="Contact" Language="C#" MasterPageFile="~/Site.master"  
    AutoEventWireup="true" CodeBehind="Contact.aspx.cs" Inherits="WebApp.Contact" %> 
 
<asp:Content ID="Content1" ContentPlaceHolderID="MainContent" runat="server"> 
 
    <h2>Contact Us</h2> 
 
    <p> 
        If you have any questions, feel free to contact us using the form below. 
    </p> 
 
    <table> 
        <tr> 
            <td>Name:</td> 
            <td> 
                <asp:TextBox ID="txtName" runat="server" Width="250px"></asp:TextBox> 
            </td> 
        </tr> 
 
        <tr> 
            <td>Email:</td> 
            <td> 
                <asp:TextBox ID="txtEmail" runat="server" Width="250px"></asp:TextBox> 
            </td> 
        </tr> 
 
        <tr> 
            <td>Message:</td> 
            <td> 
                <asp:TextBox ID="txtMessage" runat="server" TextMode="MultiLine"  
                    Width="250px" Height="100px"></asp:TextBox> 
            </td> 
        </tr> 
 
        <tr> 
            <td></td> 
            <td> 
                <asp:Button ID="btnSubmit" runat="server" Text="Send"  
                    OnClick="btnSubmit_Click" /> 
            </td> 
        </tr> 
    </table> 
 
    <br /> 
 
    <asp:Label ID="lblResult" runat="server" ForeColor="Green"></asp:Label> 
 
</asp:Content> 

Contact.aspx.cs 
using System; 
namespace WebApp 
{ 
public partial class Contact : System.Web.UI.Page 
{ 
protected void Page_Load(object sender, EventArgs e) 
{ 
} 
protected void btnSubmit_Click(object sender, EventArgs e) 
{ 
lblResult.Text = "Thank you, " + txtName.Text + "! Your message has been submitted."; 
} 
} 
}
