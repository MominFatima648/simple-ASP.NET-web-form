Step 1: Add Layout to the Master Page 
<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" 
Inherits="WebApp.Site" %> 
<!DOCTYPE html> 
<html> 
<head runat="server"> 
<title>My Website</title> 
<link href="Styles/site.css" rel="stylesheet" /> 
</head> 
<body> 
<!-- Header --> 
<div style="background:#0078d4; color:white; padding:15px;"> 
<h2>My Website Header</h2> 
<a href="Home.aspx" style="color:white;">Home</a> | 
<a href="About.aspx" style="color:white;">About</a> | 
<a href="Contact.aspx" style="color:white;">Contact</a> 
</div> 
<hr /> 
<form id="form1" runat="server"> 
<!-- Content Placeholder --> 
<asp:ContentPlaceHolder ID="MainContent" 
runat="server"></asp:ContentPlaceHolder> 
</form> 
<hr /> 
<!-- Footer --> 
<div style="background:#f5f5f5; padding:10px; text-align:center;"> 
© 2025 My Website 
</div> 
</body> 
</html> 

Step 2: Content Page Code (Home.aspx) 
<%@ Page Title="" Language="C#" MasterPageFile="~/Site.master" AutoEventWireup="true" 
CodeBehind="Home.aspx.cs" Inherits="WebApp.Home" %> 
<asp:Content ID="Content1" ContentPlaceHolderID="MainContent" runat="server"> 
<h3>Welcome to My Website</h3> 
<asp:Label ID="lblMessage" runat="server" Text=""></asp:Label> 
<br /><br /> 
<asp:TextBox ID="txtName" runat="server"></asp:TextBox> 
<br /><br /> 
<asp:Button ID="btnShow" runat="server" Text="Click Me" OnClick="btnShow_Click" /> 
</asp:Content> 
Code-Behind for Content Page (Home.aspx.cs) 
using System; 
namespace WebApp 
{ 
public partial class Home : System.Web.UI.Page 
{ 
protected void Page_Load(object sender, EventArgs e) 
{ 
} 
protected void btnShow_Click(object sender, EventArgs e) 
{ 
lblMessage.Text = "Welcome " + txtName.Text + "!"; 
} 
} 
} 

