<asp:Label Text="Enter First Number: " runat="server" /> 
<asp:TextBox ID="txtNum1" runat="server" /><br /><br /> 
<asp:Label Text="Enter Second Number: " runat="server" /> 
<asp:TextBox ID="txtNum2" runat="server" /><br /><br /> 
