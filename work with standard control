using System; 
using System.Text; 
public partial class ControlsDemo : System.Web.UI.Page 
{ 
protected void btnSubmit_Click(object sender, EventArgs e) 
{ 
StringBuilder result = new StringBuilder(); 
// TextBox value 
result.Append("Name: " + txtName.Text + "<br/>"); 
// RadioButtonList value 
result.Append("Gender: " + rblGender.SelectedValue + "<br/>"); 
// CheckBoxList values 
result.Append("Hobbies: "); 
foreach (var item in cblHobbies.Items) 
{ 
var listItem = (System.Web.UI.WebControls.ListItem)item; 
            if (listItem.Selected) 
            { 
                result.Append(listItem.Text + " "); 
            } 
        } 
        result.Append("<br/>"); 
 
        // DropDownList value 
        result.Append("Country: " + ddlCountry.SelectedValue + "<br/>"); 
 
        // Display result 
        lblResult.Text = result.ToString(); 
    } 
} 
